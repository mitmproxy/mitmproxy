<Window x:Class="OximyWindows.Views.TrayPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:OximyWindows.Views"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="340" Height="480"
        Deactivated="Window_Deactivated">

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="5"
                              Opacity="0.2"
                              Direction="270"/>
        </Border.Effect>

        <Grid>
            <!-- Invisible rounded mask for clipping child content to the border's rounded corners.
                 Without this, child views with their own Background paint a rectangle that
                 bleeds over the top corners of the 12 px rounded window. -->
            <Border x:Name="ClipMask" CornerRadius="11" Background="White"/>

            <!-- Content clipped to rounded shape -->
            <Grid>
                <Grid.OpacityMask>
                    <VisualBrush Visual="{Binding ElementName=ClipMask}"/>
                </Grid.OpacityMask>
                <ContentControl x:Name="ContentHost"/>
            </Grid>
        </Grid>
    </Border>
</Window>
